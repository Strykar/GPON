# Copy to .env and fill in. Used by docker-compose for the gpon-exporter.
#
# The split form keeps the password out of the container's argv and out
# of `docker inspect` output. The exporter reads ONU_SSH_PASSWORD from
# the environment when --device omits the password, which is what the
# compose file does.
#
# Multi-ONU is not supported by this compose file. Use the standalone
# Python or systemd path instead -- those let you pass --device once
# per ONU with separate credentials.

ONU_HOST=192.168.1.1
ONU_PORT=22
ONU_USER=admin
ONU_SSH_PASSWORD=changeme

# Only consumed by docker-compose.yml (full stack). Sets the Grafana
# admin password on first boot. If you leave the default "admin",
# Grafana will force a password change at first login anyway.
GRAFANA_ADMIN_PASSWORD=admin
