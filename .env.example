# Copy to .env and fill in. Used by docker-compose for the gpon-exporter.

# ONU connection string: user:password@host[:port]
# Repeat with newlines / additional vars if you have multiple ONUs --
# the compose file passes a single ONU_DEVICE; for multi-ONU, use the
# standalone Python or systemd path.
ONU_DEVICE=admin:changeme@192.168.1.1:22
